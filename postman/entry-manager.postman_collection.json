              "name": "Register Transaction",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "traceparent",
                    "value": "00-1234567890abcdef1234567890abcdef-abcdef1234567890-01",
                    "type": "text",
                    "disabled": true
                  },
                  {
                    "key": "x-correlation-id",
                    "value": "{{$guid}}",
                    "type": "text"
                  },
                  {
                    "key": "x-idempotency-key",
                    "value": "{{$guid}}",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"categoryId\": \"{{category-id:valid}}\",\n    \"title\": \"{{$randomCatchPhrase}}\",\n    \"value\": {{$randomInt}},\n    \"date\": \"{{$isoTimestamp}}\"\n}",
